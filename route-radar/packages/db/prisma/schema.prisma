// Prisma schema for RouteRadar
// Dev: SQLite. To switch to Postgres later: change provider + DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  DISPATCHER
  DRIVER
  CLIENT
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(DISPATCHER)
  createdAt    DateTime @default(now())

  // For drivers: routes assigned to them
  routes       Route[]  @relation("DriverRoutes")
  // For dispatchers: deliveries they created
  deliveries   Delivery[] @relation("CreatedBy")
}

model Address {
  id         String     @id @default(cuid())
  label      String
  street     String
  city       String
  postalCode String
  lat        Float
  lng        Float
  createdAt  DateTime   @default(now())

  deliveries Delivery[]
}

model Delivery {
  id          String         @id @default(cuid())
  reference   String         @unique
  recipient   String
  phone       String?
  notes       String?
  status      DeliveryStatus @default(PENDING)
  priority    Int            @default(0)

  addressId   String
  address     Address        @relation(fields: [addressId], references: [id])

  createdById String
  createdBy   User           @relation("CreatedBy", fields: [createdById], references: [id])

  routeId     String?
  route       Route?         @relation(fields: [routeId], references: [id])
  stopOrder   Int?

  deliveredAt DateTime?
  proofNote   String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([routeId])
}

model Route {
  id           String     @id @default(cuid())
  name         String
  date         DateTime
  driverId     String?
  driver       User?      @relation("DriverRoutes", fields: [driverId], references: [id])
  startLat     Float?
  startLng     Float?
  totalDistance Float?    // meters, filled after optimization
  totalDuration Float?    // seconds
  optimizedAt  DateTime?

  deliveries   Delivery[]
  createdAt    DateTime   @default(now())
}
